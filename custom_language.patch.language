		"ITEM_PERSONALSHIELD_NAME": "small shield potion",
		"ITEM_PERSONALSHIELD_PICKUP": "Gain a <style=cIsHealing>shield</style> equal to <style=cIsHealing>8%</style> <style=cStack>(+8% per stack)</style> of your maximum health. Recharges outside of danger.",
		"ITEM_PHASING_NAME": "the dead ringer",

		"ITEM_MINORCONSTRUCTONKILL_NAME": "ipad child conspiracy tiktok",
		"ITEM_MINORCONSTRUCTONKILL_PICKUP": "Killing elite monsters spawns an <style=cIsDamage>Alpha Construct</style> with bonus <style=cIsDamage>300%</style> damage and <style=cIsHealing>300% health</style>. Limited to <style=cIsUtility>4</style> <style=cStack>(+4 per stack)</style>.",
		"ITEM_MISSILEVOID_NAME": "six dollar plasma srimp special",
		"ITEM_MISSILEVOID_PICKUP": "Gain a <style=cIsHealing>shield</style> equal to <style=cIsHealing>10%</style> of your maximum health. While you have a <style=cIsHealing>shield</style>, hitting an enemy fires a missile that deals <style=cIsDamage>40%</style> <style=cStack>(+50% per stack)</style> TOTAL damage. <style=cIsVoid>Corrupts all AtG Missile Mk. 1s</style>.",
		"ITEM_MISSILE_NAME": "magic missile",
		"ITEM_MISSILE_PICKUP": "<style=cIsDamage>10%</style> chance to fire a missile that deals <style=cIsDamage>300%</style> <style=cStack>(+300% per stack)</style> TOTAL damage.",
		"ITEM_MONEYLOAN_PICKUP": "At the beginning of every stage, receive <style=cIsDamage>$200 <style=cStack>(+$200 per stack, scales over time)</style></style>, but also gain an equal amount of <style=cDeath>debt</style>. <style=cDeath>All further gold gained goes towards paying off your debt</style>. Paying off your debt destroys this item.",
